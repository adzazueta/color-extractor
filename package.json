{
    "name": "@adzazueta/color-extractor",
    "version": "0.1.1",
    "description": "ESM-only npm package for extracting perceptually meaningful primary and secondary colors from images in browser and Node.js",
    "type": "module",
    "keywords": [
        "color",
        "extraction",
        "palette",
        "image",
        "cielab",
        "kmeans",
        "typescript",
        "esm"
    ],
    "author": "Alexis D. Zazueta <alexisd.zazueta@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/adzazueta/color-extractor.git"
    },
    "bugs": {
        "url": "https://github.com/adzazueta/color-extractor/issues"
    },
    "homepage": "https://github.com/adzazueta/color-extractor#readme",
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.7.0",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/browser/index.js",
            "node": "./dist/node/index.js",
            "default": "./dist/browser/index.js"
        },
        "./browser": {
            "types": "./dist/browser/index.d.ts",
            "import": "./dist/browser/index.js"
        },
        "./node": {
            "types": "./dist/node/index.d.ts",
            "import": "./dist/node/index.js"
        },
        "./core": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "pnpm sync-version && tsdown && node scripts/check-build-warnings.mjs",
        "check-build-warnings": "node scripts/check-build-warnings.mjs",
        "changeset": "changeset",
        "release": "changeset publish",
        "sync-version": "node scripts/sync-version.mjs",
        "check-version": "pnpm sync-version && git diff --quiet src/generated/version.ts || (echo 'error: src/generated/version.ts is out of sync — run pnpm sync-version and commit the result'; exit 1)",
        "test": "vitest run",
        "test:verbose": "vitest run --reporter=verbose",
        "test:watch": "vitest",
        "test:smoke": "node scripts/smoke.mjs",
        "verify-fixtures": "node scripts/verify-fixtures.mjs",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "pnpm check-version && pnpm build && pnpm test && pnpm typecheck && pnpm test:smoke",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "prepare": "node -e \"try{require('child_process').execFileSync('simple-git-hooks',{stdio:'pipe'})}catch(e){}\""
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged && pnpm typecheck"
    },
    "lint-staged": {
        "*.{js,ts,cjs,mjs}": [
            "biome check --write --no-errors-on-unmatched",
            "vitest related --run --passWithNoTests"
        ]
    },
    "peerDependencies": {
        "sharp": "^0.33.0"
    },
    "peerDependenciesMeta": {
        "sharp": {
            "optional": true
        }
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.4",
        "@changesets/cli": "^2.31.1",
        "@types/node": "^26.1.0",
        "lint-staged": "^17.0.8",
        "publint": "^0.3.21",
        "sharp": "^0.35.0",
        "simple-git-hooks": "^2.13.1",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.0",
        "unrun": "^0.3.1",
        "vitest": "^4.1.0"
    }
}
