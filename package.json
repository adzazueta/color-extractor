{
  "name": "@adzazueta/color-extractor",
  "version": "0.1.0",
  "description": "ESM-only npm package for extracting perceptually meaningful primary and secondary colors from images in browser and Node.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "color",
    "extraction",
    "palette",
    "image",
    "cielab",
    "kmeans",
    "typescript",
    "esm"
  ],
  "author": "Alexis D. Zazueta",
  "engines": {
    "node": ">=20.3.0"
  },
  "packageManager": "pnpm@10.7.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.js",
      "default": "./dist/browser/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "publint": "^0.3.21",
    "sharp": "^0.35.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "unrun": "^0.3.1",
    "vitest": "^4.1.0"
  }
}
